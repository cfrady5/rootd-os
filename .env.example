# ── Supabase (optional — app runs in demo mode without these) ──────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Required for /api/match to work (set in Vercel environment variables) ─────
# Get a Google Places API key: https://console.cloud.google.com
# Enable: Geocoding API + Places API (Legacy)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Get an OpenAI API key: https://platform.openai.com/api-keys
# Used for AI-generated match reasons (gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key
